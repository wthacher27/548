# --- Build stage ---
FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# --- Run stage ---
FROM node:20-alpine
WORKDIR /app

COPY --from=build /app/dist/my-frontend ./dist/my-frontend

EXPOSE 4000
CMD ["node", "dist/my-frontend/server/server.mjs"]
